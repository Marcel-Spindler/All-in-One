# ============================================================
#  Cloud-Konfiguration - VORLAGE
#  Diese Datei kopieren als ".env" und Werte ergaenzen.
#  NIEMALS .env ins Git oder in eine ZIP packen!
# ============================================================

# Eure oeffentliche Domain (oder VM-IP gefolgt von .nip.io)
# Beispiele:
#   PUBLIC_DOMAIN=tools.hellofresh-internal.de
#   PUBLIC_DOMAIN=34.159.123.45.nip.io
PUBLIC_DOMAIN=

# Google OAuth Client (aus GCP Console -> APIs & Services -> Credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Random 32 Byte Base64 - generieren mit:
#   openssl rand -base64 32
OAUTH2_COOKIE_SECRET=

# PS Copilot KI-Schluessel
GEMINI_API_KEY=
