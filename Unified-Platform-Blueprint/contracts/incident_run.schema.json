{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "incident_run.schema.json",
  "title": "Incident Run",
  "type": "object",
  "required": [
    "runId",
    "tool",
    "status",
    "startedAt",
    "inputFiles",
    "outputFiles",
    "metrics"
  ],
  "properties": {
    "runId": { "type": "string", "minLength": 8 },
    "tool": { "const": "incident-tool" },
    "status": { "enum": ["started", "success", "warning", "failed"] },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "inputFiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputFiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "productionDate": { "type": "string" },
        "incidentCount": { "type": "integer", "minimum": 0 },
        "affectedBoxes": { "type": "integer", "minimum": 0 },
        "mappedCustomers": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
